{
  "name": "eslint-config-vladpuz-react",
  "version": "2.2.1",
  "description": "My ESLint config for React",
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladpuz/eslint-config-vladpuz-react.git"
  },
  "license": "MIT",
  "author": "Vladislav Puzyrev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format",
    "format": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build && npm run check && npm run test",
    "prepare": "husky",
    "test": "node --test",
    "test-update-snapshots": "node --test --test-update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.17.1",
    "eslint-config-vladpuz": "^4.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "prettier-config-vladpuz": "^3.0.1",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^6.0.0"
  }
}
